#!/usr/bin/env python3

import sys
import datetime


def days_in_month(year, month):
    if month == 12:
        next_month = datetime.date(year + 1, 1, 1)
    else:
        next_month = datetime.date(year, month + 1, 1)
    last_day = next_month - datetime.timedelta(days=1)
    return last_day.day


def add_months(year, month, offset):
    # Convert to a 0-indexed total months count, add offset, convert back
    total = year * 12 + (month - 1) + offset
    new_year = total // 12
    new_month = total % 12 + 1
    return new_year, new_month


def render_calendar(year, month):
    month_names = [
        "January", "February", "March", "April", "May", "June",
        "July", "August", "September", "October", "November", "December"
    ]

    # Header: month name and year, centered over the grid
    grid_width = 7 * 4 - 1  # 7 columns, each 4 chars wide ("XX  "), minus trailing space
    title = month_names[month - 1] + " " + str(year)
    print(title.center(grid_width))
    print("Mon Tue Wed Thu Fri Sat Sun")

    # weekday() returns 0 for Monday, 6 for Sunday — perfect for a Monday-start grid
    first_weekday = datetime.date(year, month, 1).weekday()
    total_days = days_in_month(year, month)

    # Build a flat list of cells: leading blanks, then day numbers
    cells = [""] * first_weekday
    for day in range(1, total_days + 1):
        cells.append(str(day))

    # Pad the end so the total is a multiple of 7
    while len(cells) % 7 != 0:
        cells.append("")

    # Print rows of 7
    for i in range(0, len(cells), 7):
        row = cells[i:i + 7]
        line = ""
        for cell in row:
            line += cell.rjust(2) + "  "
        print(line.rstrip())


def main():
    today = datetime.date.today()
    year = today.year
    month = today.month

    if len(sys.argv) > 1:
        try:
            offset = int(sys.argv[1])
        except ValueError:
            print("Error: argument must be an integer like -1, 0, +2")
            sys.exit(1)
        year, month = add_months(year, month, offset)

    render_calendar(year, month)


if __name__ == "__main__":
    main()
